#!/bin/sh
# Enhanced health check - JSON output (busybox only)

TOR_LOG="${TOR_LOG_DIR:-/var/log/tor}/notices.log"
TOR_DATA="${TOR_DATA_DIR:-/var/lib/tor}"

sanitize_num() {
    v=$(printf '%s' "$1" | tr -cd '0-9')
    [ -z "$v" ] && v=0
    printf '%s' "$v"
}

if ! pgrep -x tor >/dev/null 2>&1; then
    echo '{"status":"down","bootstrap":0,"reachable":"unknown","errors":0}'
    exit 1
fi

TOR_PID=$(pgrep -x tor)
TOR_PID=$(sanitize_num "$TOR_PID")
UPTIME=$(ps -o pid=,etime= 2>/dev/null | awk -v target="$TOR_PID" '
    $1 == target { print $2; exit }
')
[ -n "$UPTIME" ] || UPTIME="unknown"

BOOTSTRAP=0
if [ -f "$TOR_LOG" ]; then
    if grep -q "Bootstrapped 100%" "$TOR_LOG"; then
        BOOTSTRAP=100
    else
        BOOTSTRAP=$(grep "Bootstrapped" "$TOR_LOG" | tail -1 | sed 's/.*Bootstrapped \([0-9]*\)%.*/\1/' 2>/dev/null || echo "0")
    fi
fi
BOOTSTRAP=$(sanitize_num "$BOOTSTRAP")

REACHABLE="unknown"
if [ -f "$TOR_LOG" ]; then
    REACHABILITY_EVENT=$(grep -E \
        'Self-testing indicates your ORPort.*is reachable from the outside|ORPort not reachable|not managed to confirm reachability for its ORPort' \
        "$TOR_LOG" 2>/dev/null | tail -n 1 || true)

    case "$REACHABILITY_EVENT" in
        *"Self-testing indicates your ORPort"*"is reachable from the outside"*)
            REACHABLE="true"
            ;;
        *"ORPort not reachable"*|*"not managed to confirm reachability for its ORPort"*)
            REACHABLE="false"
            ;;
    esac
fi

ERRORS=$(grep -c "\[err\]" "$TOR_LOG" 2>/dev/null || true)
[ -n "$ERRORS" ] || ERRORS=0
ERRORS=$(sanitize_num "$ERRORS")

NICKNAME="unknown"
FINGERPRINT="unknown"
if [ -f "$TOR_DATA/fingerprint" ]; then
    NICKNAME=$(cat "$TOR_DATA/fingerprint" | awk '{print $1}')
    FINGERPRINT=$(cat "$TOR_DATA/fingerprint" | awk '{print $2}')
fi

TOR_VERSION=$(tor --version 2>/dev/null | head -n1 | sed 's/Tor version //' || echo "unknown")

RELAY_MODE="${TOR_RELAY_MODE:-unknown}"
TORRC="${TOR_CONFIG:-/etc/tor/torrc}"
if [ -f "$TORRC" ]; then
    if grep -q "^BridgeRelay 1" "$TORRC" 2>/dev/null; then
        RELAY_MODE="bridge"
    elif grep -q "^ExitRelay 1" "$TORRC" 2>/dev/null; then
        RELAY_MODE="exit"
    elif grep -q "^ExitRelay 0" "$TORRC" 2>/dev/null; then
        RELAY_MODE="guard"
    fi
fi

CONFIG_SOURCE="unknown"
if [ -f "$TORRC" ]; then
    if grep -q "^# Generated Tor configuration" "$TORRC" 2>/dev/null; then
        CONFIG_SOURCE="environment"
    else
        CONFIG_SOURCE="mounted"
    fi
fi

BUILD_VERSION="unknown"
if [ -f "/build-info.txt" ]; then
    BUILD_VERSION=$(awk -F': ' '/^Version:/ {print $2}' /build-info.txt)
    [ -z "$BUILD_VERSION" ] && BUILD_VERSION="unknown"
fi

cat <<EOF
{
  "status": "up",
  "pid": $TOR_PID,
  "uptime": "$UPTIME",
  "bootstrap": $BOOTSTRAP,
  "reachable": "$REACHABLE",
  "errors": $ERRORS,
  "nickname": "$NICKNAME",
  "fingerprint": "$FINGERPRINT",
  "tor_version": "$TOR_VERSION",
  "relay_mode": "$RELAY_MODE",
  "build_version": "$BUILD_VERSION",
  "config_source": "$CONFIG_SOURCE"
}
EOF
